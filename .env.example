# ── Copy this to .env.local and fill in real values ──────────
# .env.local is gitignored — NEVER commit real keys

# From Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# ⚠️  Service role key — SERVER SIDE ONLY, no NEXT_PUBLIC_ prefix
# From Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: protect the dashboard with a simple password
# Leave blank to disable password protection
DASHBOARD_PASSWORD=
